{
  "name": "deezer-public-api",
  "version": "2.1.0",
  "description": "Node.js wrapper for the Deezer Public API using native fetch and TypeScript.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "deezer-api",
    "deezer",
    "api",
    "rest",
    "rest-api",
    "typescript",
    "esm"
  ],
  "license": "MIT",
  "author": "Zao Soula <contact@zaosoula.fr> (https://github.com/zaosoula/)",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zaosoula/deezer-public-api.git"
  },
  "bugs": {
    "url": "https://github.com/zaosoula/deezer-public-api/issues"
  },
  "homepage": "https://github.com/zaosoula/deezer-public-api",
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "prepublishOnly": "node -e \"if(!process.env.GITHUB_ACTIONS) { console.error('\\n\\nERROR: Local publishing is disabled. Use GitHub Actions.\\n\\n'); process.exit(1); }\"",
    "test": "vitest run --coverage --typecheck",
    "test:watch": "vitest",
    "sync-docs": "tsx scripts/sync-docs.ts",
    "update-fixtures": "tsx scripts/generate-fixtures.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "changelogen": "^0.6.2",
    "make-coverage-badge": "^1.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "type-fest": "^5.4.4",
    "typescript": "^6.0.2",
    "unbuild": "^3.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}
